#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

REDE="${1:-172.16.1.0/24}"
KNOCK_PORTS=(13 37 30000 3000 1337)   # sequência exata do pcap
BACKDOOR_PORT=1337                     # porta HTTP aberta após knock
KNOCK_TIMEOUT=1                        # segundos por knock
CURL_TIMEOUT=5                         # timeout do curl
INFECTADOS=()

echo -e "${BOLD}"
echo -e "${NC}"

if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}[ERRO]${NC} Execute com sudo: sudo bash $0"
    exit 1
fi

for dep in hping3 curl; do
    if ! command -v $dep &>/dev/null; then
        echo -e "${RED}[ERRO]${NC} '$dep' não encontrado. Instale com: apt install $dep"
        exit 1
    fi
done

calcular_ips() {
    local rede="$1"
    local base_ip="${rede%/*}"
    local prefixo="${rede#*/}"

    # Converter IP base para inteiro
    IFS='.' read -r a b c d <<< "$base_ip"
    local ip_int=$(( (a << 24) | (b << 16) | (c << 8) | d ))

    # Máscara
    local mask=$(( 0xFFFFFFFF << (32 - prefixo) & 0xFFFFFFFF ))
    local total=$(( (1 << (32 - prefixo)) - 2 ))  # -2 (rede e broadcast)
    local inicio=$(( (ip_int & mask) + 1 ))

    for (( i=0; i<total; i++ )); do
        local ip_atual=$(( inicio + i ))
        printf "%d.%d.%d.%d\n" \
            $(( (ip_atual >> 24) & 0xFF )) \
            $(( (ip_atual >> 16) & 0xFF )) \
            $(( (ip_atual >>  8) & 0xFF )) \
            $(( ip_atual & 0xFF ))
    done
}

testar_host() {
    local ip="$1"

    # Verificar se host está ativo (ping rápido)
    if ! ping -c 1 -W 1 "$ip" &>/dev/null; then
        return
    fi

    echo -e "${CYAN}[*]${NC} Host ativo: ${BOLD}$ip${NC} — enviando knock sequence..."

    # Enviar sequência de knock
    for porta in "${KNOCK_PORTS[@]}"; do
        hping3 -S -p "$porta" -c 1 "$ip" &>/dev/null
        sleep 0.2
    done

    # Aguardar o servidor processar os knocks
    sleep 0.5

    # Verificar se a porta 1337 abriu e retorna conteúdo do malware
    resposta=$(curl -s -m "$CURL_TIMEOUT" "http://$ip:${BACKDOOR_PORT}/" 2>/dev/null)

    if echo "$resposta" | grep -qi "ricardocry\|infected\|malware\|chave"; then
        echo -e "${RED}${BOLD}[!!!] INFECTADO${NC} — $ip"
        echo -e "      Resposta: $(echo "$resposta" | grep -i "ricardocry\|infected\|chave" | head -3)"
        INFECTADOS+=("$ip")

        # Salvar resultado
        echo "========================================" >> infectados.txt
        echo "HOST: $ip" >> infectados.txt
        echo "DATA: $(date)" >> infectados.txt
        echo "RESPOSTA:" >> infectados.txt
        echo "$resposta" >> infectados.txt
        echo "" >> infectados.txt
    else
        echo -e "${GREEN}[OK]${NC} $ip — sem resposta do malware"
    fi
}

LISTA_IPS=($(calcular_ips "$REDE"))
TOTAL=${#LISTA_IPS[@]}

echo -e "${YELLOW}[*]${NC} Rede alvo : ${BOLD}$REDE${NC}"
echo -e "${YELLOW}[*]${NC} Total IPs : ${BOLD}$TOTAL${NC}"
echo -e "${YELLOW}[*]${NC} Iniciando : $(date)\n"

CONTADOR=0
for ip in "${LISTA_IPS[@]}"; do
    CONTADOR=$(( CONTADOR + 1 ))
    echo -ne "${YELLOW}[${CONTADOR}/${TOTAL}]${NC} Testando $ip...\r"
    testar_host "$ip"
done

echo ""
echo -e "${BOLD}"
printf  "║  Hosts verificados : %-32s║\n" "$TOTAL"
printf  "║  Hosts infectados  : %-32s║\n" "${#INFECTADOS[@]}"

if [[ ${#INFECTADOS[@]} -gt 0 ]]; then
    echo "║  IPs INFECTADOS:                                     ║"
    for ip in "${INFECTADOS[@]}"; do
        printf "║    %-50s║\n" "→ $ip"
    done
    echo "Detalhes salvos em: infectados.txt"
else
    echo "Nenhum host infectado encontrado."
fi

echo -e "${NC}"
echo -e "${YELLOW}[*]${NC} Finalizado: $(date)"
